from fastapi import FastAPI
from pydantic import BaseModel, HttpUrl
import httpx, asyncio
from typing import List
app = FastAPI()

class URLRequest(BaseModel):
    urls: list[HttpUrl]

class URLResponse(BaseModel):
    url: HttpUrl
    status: int | None
    reachable: bool

async def Fetch_url(client:httpx.AsyncClient, url: HttpUrl):
    try:
        response = await client.get(str(url))
        return {
            "url": url,
            "status": response.status_code,
            "reachable": True
        }

    except httpx.RequestError:
        return {
            "url": url,
            "status": None,
            "reachable": False
        }

@app.post("/check", response_model=List[URLResponse])
async def check_status(data: URLRequest):
    async with httpx.AsyncClient(timeout=5.0) as client:
        tasks = [Fetch_url(client, url) for url in data.urls]
        results = await asyncio.gather(*tasks)

    return results
